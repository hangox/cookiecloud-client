{
  "name": "cookiecloud-client",
  "version": "1.0.0",
  "description": "CookieCloud client for Node.js — fetch and decrypt browser cookies synced via CookieCloud",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm test:coverage && pnpm build",
    "prepublishOnly": "pnpm check"
  },
  "keywords": [
    "cookiecloud",
    "cookie",
    "browser",
    "sync",
    "decrypt"
  ],
  "author": "hangox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hangox/cookiecloud-client.git"
  },
  "homepage": "https://github.com/hangox/cookiecloud-client#readme",
  "bugs": {
    "url": "https://github.com/hangox/cookiecloud-client/issues"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
